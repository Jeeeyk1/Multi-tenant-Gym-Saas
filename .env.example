# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=gym_user
POSTGRES_PASSWORD=gym_password
POSTGRES_DB=gym_saas
POSTGRES_PORT=5432

# Constructed from the values above
DATABASE_URL=postgresql://gym_user:gym_password@localhost:5432/gym_saas

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@localhost:6379

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3001
API_PREFIX=api

# ─── Web ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
