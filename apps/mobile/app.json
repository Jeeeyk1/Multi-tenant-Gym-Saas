{
  "expo": {
    "name": "FitZone",
    "slug": "gym-saas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gymSaasMobile",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0f0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymSaas.mobile",
      "infoPlist": {
        "NSHealthShareUsageDescription": "FitZone reads your workout calories and heart rate so you can track your fitness progress.",
        "NSHealthUpdateUsageDescription": "FitZone saves your workout sessions to Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "package": "com.gymSaas.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0f0f0f"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to scan member QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
