{
  "expo": {
    "name": "FitZone",
    "slug": "gym-saas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gymSaasMobile",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0f0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymSaas.mobile"
    },
    "android": {
      "package": "com.gymSaas.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0f0f0f"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
