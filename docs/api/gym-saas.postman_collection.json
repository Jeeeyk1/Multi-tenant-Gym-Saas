          }
        },
        {
          "name": "Update — Change title + pin",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Welcome to Dev Gym! (Updated)\",\n  \"isPinned\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/gyms/{{gymId}}/announcements/{{announcementId}}",
