            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"publishAt\": \"2099-06-01T09:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/gyms/{{gymId}}/announcements/{{announcementId}}",
              "host": ["{{baseUrl}}"],
              "path": ["gyms", "{{gymId}}", "announcements", "{{announcementId}}"]
            }
          }
        },
        {
          "name": "Update — Publish now (clear publishAt)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
